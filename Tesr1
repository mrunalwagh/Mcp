const tools = require('./server');

const method = process.argv[2];
const arg1 = process.argv[3];
const arg2 = process.argv[4];

async function run() {
  try {

    if (method === "runTest") {
      const result = await tools.runTest(arg1);
      console.log(result);
    }

    else if (method === "createTest") {
      const result = await tools.createTestFile(arg1, arg2);
      console.log(result);
    }

    else if (method === "fixTest") {
      const result = await tools.fixTestFile(arg1);
      console.log(result);
    }

    else if (method === "agent") {
      require('./agent');
    }

    else {
      console.log("Invalid method");
    }

  } catch (err) {
    console.error("Error:", err);
  }
}

run();
