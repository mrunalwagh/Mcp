const { exec } = require('child_process');

function runTest(testFile) {
  return new Promise((resolve, reject) => {
    exec(`npx playwright test ${testFile}`, (error, stdout, stderr) => {
      if (error) {
        reject(stderr);
      } else {
        resolve(stdout);
      }
    });
  });
}

module.exports = {
  runTest
};
