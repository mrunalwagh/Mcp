const { exec } = require('child_process');
const fs = require('fs');

// 🔹 Run Playwright Test
function runTest(testFile) {
  return new Promise((resolve, reject) => {
    exec(`npx playwright test ${testFile}`, (error, stdout, stderr) => {
      if (error) {
        reject(stderr);
      } else {
        resolve(stdout);
      }
    });
  });
}

// 🔹 Create Test File
function createTestFile(fileName, code) {
  return new Promise((resolve, reject) => {
    const path = `tests/${fileName}`;
    fs.writeFile(path, code, (err) => {
      if (err) reject(err);
      else resolve(`File created: ${path}`);
    });
  });
}

// 🔹 Fix Test File (basic self-healing)
function fixTestFile(fileName) {
  return new Promise((resolve, reject) => {
    const path = `tests/${fileName}`;
    let content = fs.readFileSync(path, 'utf-8');

    // Dummy fix (replace locator)
    content = content.replace("#username", "#user-email");

    fs.writeFileSync(path, content);
    resolve("Test file updated with new locator");
  });
}

module.exports = {
  runTest,
  createTestFile,
  fixTestFile
};
